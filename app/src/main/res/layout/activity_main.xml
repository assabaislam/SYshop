<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_bg"
    tools:context=".activities.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header"
            android:paddingStart="@dimen/spacing_xlarge"
            android:paddingTop="@dimen/spacing_xlarge"
            android:paddingEnd="@dimen/spacing_xlarge"
            android:paddingBottom="@dimen/spacing_medium">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/cartContainer"
                    android:orientation="vertical"
                    android:layout_marginEnd="@dimen/spacing_small">

                    <TextView
                        android:id="@+id/welcomeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/welcome_back"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_welcome" />

                    <TextView
                        android:id="@+id/logoText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="5dp"
                        android:text="@string/app_name"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_logo"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/cartContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/cartBtn"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_circle_icon"
                        android:padding="10dp"
                        android:src="@drawable/ic_cart"
                        app:tint="@color/white"
                        android:contentDescription="cart" />

                    <TextView
                        android:id="@+id/cartBadgeText"
                        android:layout_width="@dimen/cart_badge_size"
                        android:layout_height="@dimen/cart_badge_size"
                        android:layout_gravity="end|top"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_cart_badge"
                        android:gravity="center"
                        android:text="@string/cart_badge_default"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_tiny"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>
            </RelativeLayout>

            <!-- SEARCH BAR -->
            <LinearLayout
                android:id="@+id/searchContainer"
                android:layout_width="match_parent"
                android:layout_height="@dimen/search_bar_height"
                android:layout_marginTop="0dp"
                android:background="@drawable/bg_search"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/spacing_medium"
                android:paddingEnd="@dimen/spacing_medium">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/text_gray_dark"
                    android:contentDescription="@string/content_desc_search" />

                <EditText
                    android:id="@+id/searchEdit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/search_hint"
                    android:paddingStart="@dimen/spacing_small"
                    android:paddingEnd="@dimen/spacing_small"
                    android:textColor="@color/black_soft"
                    android:textColorHint="@color/search_hint_color"
                    android:textSize="15sp"
                    android:autofillHints="name"
                    android:inputType="text"
                    android:minHeight="48dp" />

                <ImageView
                    android:id="@+id/clearSearchBtn"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/text_gray_dark"
                    android:contentDescription="Clear search"
                    android:visibility="gone"
                    android:padding="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- CONTENT -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/mainScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/contentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing_xlarge"
                android:paddingBottom="@dimen/spacing_medium">

                <!-- Categories -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/categoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/spacing_medium"
                    android:paddingEnd="@dimen/spacing_medium"
                    android:nestedScrollingEnabled="false" />

                <!-- Modern Banner -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:layout_marginStart="@dimen/spacing_medium"
                    android:layout_marginEnd="@dimen/spacing_medium"
                    app:cardBackgroundColor="@color/offer_bg"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="4dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Decorative floating element -->
                        <View
                            android:id="@+id/offerImageBg"
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:background="@drawable/bg_circle_icon"
                            android:alpha="0.3"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:layout_marginEnd="-60dp"
                            android:layout_marginBottom="-40dp" />

                        <!-- Modern Image Frame -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/imageFrame"
                            android:layout_width="130dp"
                            android:layout_height="130dp"
                            android:layout_marginEnd="20dp"
                            app:cardCornerRadius="28dp"
                            app:cardElevation="8dp"
                            app:cardBackgroundColor="@color/white"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:id="@+id/offerImage"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="0dp"
                                android:scaleType="centerCrop"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:contentDescription="@string/content_desc_offer" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="28dp"
                            android:paddingEnd="12dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/imageFrame"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <TextView
                                android:id="@+id/offerSmallText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/special_offer"
                                android:textColor="@color/black_soft"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/offerTitleText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/up_to_40_off"
                                android:textColor="@color/navy_button"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:includeFontPadding="false" />

                            <TextView
                                android:id="@+id/offerPriceText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/offer_price_placeholder"
                                android:textColor="@color/text_gray_dark"
                                android:textSize="15sp" />

                            <Button
                                android:id="@+id/shopNowBtn"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:layout_marginTop="16dp"
                                android:backgroundTint="@color/navy_button"
                                android:text="@string/shop_now"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="24dp"
                                android:paddingEnd="24dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:cornerRadius="16dp"
                                android:textAllCaps="false" />
                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- PROMO SECTION -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xlarge"
                    android:paddingStart="@dimen/spacing_medium"
                    android:paddingEnd="@dimen/spacing_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/promoSeeAllText"
                        android:text="@string/promo_products"
                        android:textColor="@color/navy_button"
                        android:textSize="@dimen/text_heading"
                        android:textStyle="bold"
                        android:layout_marginEnd="@dimen/spacing_small" />

                    <TextView
                        android:id="@+id/promoSeeAllText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/see_all"
                        android:textColor="@color/text_gray_dark"
                        android:textSize="15sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/promoRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/promo_card_height"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/spacing_medium"
                    android:paddingEnd="@dimen/spacing_medium"
                    android:paddingBottom="12dp"
                    android:nestedScrollingEnabled="false" />

                <!-- MAIN PRODUCTS SECTION -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xlarge"
                    android:paddingStart="@dimen/spacing_medium"
                    android:paddingEnd="@dimen/spacing_medium">

                    <TextView
                        android:id="@+id/productsSectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/seeAllText"
                        android:text="@string/popular_products"
                        android:textColor="@color/navy_button"
                        android:textSize="@dimen/text_heading"
                        android:textStyle="bold"
                        android:layout_marginEnd="@dimen/spacing_small" />

                    <TextView
                        android:id="@+id/seeAllText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/see_all"
                        android:textColor="@color/text_gray_dark"
                        android:textSize="15sp" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/noProductsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:text="@string/no_products_found"
                    android:textColor="@color/text_gray_dark"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/productRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="12dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Bottom Nav -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/bg_bottom_nav"
            app:backgroundTint="@color/white"
            app:itemIconSize="20dp"
            app:itemTextColor="@color/bottom_nav_colors"
            app:itemActiveIndicatorStyle="@null"
            app:itemIconTint="@color/bottom_nav_colors"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_menu" />
    </LinearLayout>

    <!-- Floating Search Icon -->
    <ImageView
        android:id="@+id/searchIconSmall"
        android:layout_width="@dimen/icon_button_size"
        android:layout_height="@dimen/icon_button_size"
        android:layout_gravity="top|end"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="@dimen/spacing_large"
        android:background="@drawable/bg_circle_icon"
        android:elevation="12dp"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_search"
        app:tint="@color/white"
        android:visibility="gone"
        android:contentDescription="@string/content_desc_search" />

</FrameLayout>
