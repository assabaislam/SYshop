<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageAreaBg"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_image_surface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Slanted" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/favoriteItemImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/content_desc_product"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintBottom_toBottomOf="@id/imageAreaBg"
            app:layout_constraintEnd_toEndOf="@id/imageAreaBg"
            app:layout_constraintStart_toStartOf="@id/imageAreaBg"
            app:layout_constraintTop_toTopOf="@id/imageAreaBg"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Slanted" />

        <TextView
            android:id="@+id/favoriteItemName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="@string/product_name_placeholder"
            android:textColor="@color/black_soft"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/removeFavoriteBtn"
            app:layout_constraintStart_toEndOf="@id/imageAreaBg"
            app:layout_constraintTop_toTopOf="@id/imageAreaBg" />

        <TextView
            android:id="@+id/favoriteItemTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_tag_badge"
            android:includeFontPadding="false"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="@string/product_tag_best_seller"
            android:textAllCaps="true"
            android:textColor="@color/accent_coral_dark"
            android:textSize="9sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/favoriteItemName"
            app:layout_constraintTop_toBottomOf="@id/favoriteItemName" />

        <TextView
            android:id="@+id/favoriteItemPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/product_price_placeholder"
            android:textColor="@color/price_green"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imageAreaBg"
            app:layout_constraintStart_toStartOf="@id/favoriteItemName" />

        <ImageView
            android:id="@+id/removeFavoriteBtn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_surface"
            android:clickable="true"
            android:contentDescription="@string/remove_from_favorites"
            android:focusable="true"
            android:padding="9dp"
            android:src="@drawable/ic_favorite_filled"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
