<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/light_bg">

    <!-- ═══ HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xlarge"
        android:paddingTop="@dimen/spacing_xlarge"
        android:paddingEnd="@dimen/spacing_large"
        android:paddingBottom="@dimen/spacing_medium">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/backBtn"
                android:layout_width="@dimen/icon_button_size"
                android:layout_height="@dimen/icon_button_size"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:background="@drawable/bg_circle_icon"
                android:padding="10dp"
                android:src="@drawable/ic_return"
                android:contentDescription="@string/content_desc_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/my_cart"
                android:textColor="@color/white"
                android:textSize="@dimen/text_heading"
                android:textStyle="bold" />
        </RelativeLayout>
    </LinearLayout>

    <!-- ═══ CONTENT ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_large"
        android:paddingTop="@dimen/spacing_heading"
        android:paddingEnd="@dimen/spacing_large"
        android:paddingBottom="@dimen/spacing_large">

        <!-- Item count -->
        <TextView
            android:id="@+id/cartCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            android:text="@string/items_count"
            android:textColor="@color/text_gray"
            android:textSize="@dimen/text_medium" />

        <!-- Total price card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/totalPriceText"
                    android:layout_marginEnd="@dimen/spacing_small"
                    android:text="@string/order_total"
                    android:textColor="@color/text_gray"
                    android:textSize="@dimen/text_medium"
                    android:ellipsize="end"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/totalPriceText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="@string/price_zero"
                    android:textColor="@color/navy_button"
                    android:textSize="@dimen/text_heading"
                    android:textStyle="bold" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Empty state -->
        <TextView
            android:id="@+id/cartEmptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:text="@string/cart_empty"
            android:textColor="@color/text_gray"
            android:textSize="@dimen/text_large" />

        <!-- Cart items -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cartRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:clipToPadding="false" />
    </LinearLayout>

</LinearLayout>
